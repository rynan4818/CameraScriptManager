<UserControl x:Class="CameraScriptManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:CameraScriptManager.Models"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:navigation="clr-namespace:System.Windows.Navigation;assembly=PresentationFramework">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="RenameOptions" MethodName="GetValues" ObjectType="{x:Type models:RenameOption}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:RenameOption"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Paths Configuration -->
        <GroupBox Grid.Row="0" Header="パス設定" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- CustomLevels -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="CustomLevels:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CustomLevelsPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="0" Grid.Column="2" Content="参照..." Command="{Binding BrowseCustomLevelsCommand}" Margin="5"
                        ToolTip="CustomLevels フォルダを選択します"/>

                <!-- CustomWIPLevels -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="CustomWIPLevels:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CustomWIPLevelsPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="1" Grid.Column="2" Content="参照..." Command="{Binding BrowseCustomWIPLevelsCommand}" Margin="5"
                        ToolTip="CustomWIPLevels フォルダを選択します"/>

                <!-- SongScripts -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="SongScripts:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SongScriptsFolderPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="2" Grid.Column="2" Content="参照..." Command="{Binding BrowseSongScriptsFolderCommand}" Margin="5"
                        ToolTip="SongScripts フォルダを選択します"/>

                <Separator Grid.Row="3" Grid.ColumnSpan="3" Margin="0,10"/>

                <!-- OriginalScript 1 -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="元データ検索(アーカイブ/JSON) 1:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding OriginalScriptPath1, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="4" Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript1Command}" Margin="5"
                        ToolTip="元データ検索フォルダ 1 を選択します"/>

                <!-- OriginalScript 2 -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="元データ検索(アーカイブ/JSON) 3:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding OriginalScriptPath3, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="5" Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript3Command}" Margin="5"
                        ToolTip="元データ検索フォルダ 3 を選択します"/>

                <!-- OriginalScript 2 -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="元データ検索(アーカイブ/JSON) 2:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding OriginalScriptPath2, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="6" Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript2Command}" Margin="5"
                        ToolTip="元データ検索フォルダ 2 を選択します"/>

                <!-- Backup Root -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="バックアップルート:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding BackupRootPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="7" Grid.Column="2" Content="参照..." Command="{Binding BrowseBackupRootCommand}" Margin="5"
                        ToolTip="バックアップの保存先ルートを選択します"/>
            </Grid>
        </GroupBox>

        <!-- Naming Configurations -->
        <GroupBox Grid.Row="1" Header="命名規則設定" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- MapScripts Zip Naming -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="MapScripts ZIP出力名:" VerticalAlignment="Top" FontWeight="Bold" Margin="0,0,10,10"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton GroupName="ManagerZipNaming" IsChecked="{Binding IsManagerZipNamingDefault}" VerticalAlignment="Center" Margin="0,0,10,0"
                                     ToolTip="MapScripts ZIP出力で使う指定名を既定書式で生成します">
                            <TextBlock Text="デフォルト({MapId}_{SongName}_{LevelAuthorName})"/>
                        </RadioButton>
                        <RadioButton Content="カスタム" GroupName="ManagerZipNaming" IsChecked="{Binding IsManagerZipNamingCustom}" VerticalAlignment="Center" Margin="0,0,10,0"
                                     ToolTip="MapScripts ZIP出力で使う指定名をカスタム書式で生成します"/>
                        <TextBox Text="{Binding ManagerZipCustomFormat, UpdateSourceTrigger=PropertyChanged}" 
                                 IsEnabled="{Binding IsManagerZipNamingCustom}" Width="300" VerticalAlignment="Center"
                                 ToolTip="MapScripts ZIP出力時の指定名をカスタム書式で入力します"/>
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="ZIP内配置:" Foreground="Gray" Margin="0,0,0,4"/>
                        <RadioButton GroupName="ManagerZipPackaging"
                                     IsChecked="{Binding IsManagerZipPackagingFolderKeepOriginalJson}"
                                     Margin="0,0,0,4"
                                     ToolTip="元の JSON 名のまま、指定名フォルダに格納します">
                            <TextBlock Text="1. JSON名そのまま + 指定名フォルダに格納"/>
                        </RadioButton>
                        <RadioButton GroupName="ManagerZipPackaging"
                                     IsChecked="{Binding IsManagerZipPackagingFlatRenameJson}"
                                     Margin="0,0,0,4"
                                     ToolTip="JSON 名を指定名に変更して ZIP 直下に保存します">
                            <TextBlock Text="2. JSON名を指定名に変更 + フォルダなし"/>
                        </RadioButton>
                        <RadioButton GroupName="ManagerZipPackaging"
                                     IsChecked="{Binding IsManagerZipPackagingFolderSongScriptJson}"
                                     ToolTip="指定名フォルダに格納し、JSON 名は SongScript.json に固定します">
                            <TextBlock Text="3. SongScript.json + 指定名フォルダに格納"/>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>

                <!-- Copier Rename Naming -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Copier リネーム名:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,10"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Text="{Binding CopierRenameCustomFormat, UpdateSourceTrigger=PropertyChanged}" 
                             Width="300" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Tags Hint and Copy Buttons -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                    <TextBlock Text="使用可能なタグ (クリックでコピー):" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,5"/>
                    <WrapPanel>
                        <WrapPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Margin" Value="0,0,5,5"/>
                                <Setter Property="Padding" Value="8,2"/>
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Style>
                        </WrapPanel.Resources>
                        <Button Content="{}{MapId}" Command="{Binding CopyTagCommand}" CommandParameter="MapId" ToolTip="MapId タグをクリップボードにコピーします"/>
                        <Button Content="{}{SongName}" Command="{Binding CopyTagCommand}" CommandParameter="SongName" ToolTip="SongName タグをクリップボードにコピーします"/>
                        <Button Content="{}{SongSubName}" Command="{Binding CopyTagCommand}" CommandParameter="SongSubName" ToolTip="SongSubName タグをクリップボードにコピーします"/>
                        <Button Content="{}{SongAuthorName}" Command="{Binding CopyTagCommand}" CommandParameter="SongAuthorName" ToolTip="SongAuthorName タグをクリップボードにコピーします"/>
                        <Button Content="{}{LevelAuthorName}" Command="{Binding CopyTagCommand}" CommandParameter="LevelAuthorName" ToolTip="LevelAuthorName タグをクリップボードにコピーします"/>
                        <Button Content="{}{CameraScriptAuthorName}" Command="{Binding CopyTagCommand}" CommandParameter="CameraScriptAuthorName" ToolTip="CameraScriptAuthorName タグをクリップボードにコピーします"/>
                        <Button Content="{}{FileName}" Command="{Binding CopyTagCommand}" CommandParameter="FileName" ToolTip="FileName タグをクリップボードにコピーします"/>
                        <Button Content="{}{Bpm}" Command="{Binding CopyTagCommand}" CommandParameter="Bpm" ToolTip="Bpm タグをクリップボードにコピーします"/>
                    </WrapPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,5,0,0">
                        <Run Text="※ {FileName} はJSONファイル名、{CameraScriptAuthorName} は作成者（入力値）を指します。"/>
                    </TextBlock>
                </StackPanel>

                <!-- Backup Setting -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="その他の設定:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,15,10,5"/>
                <Border Grid.Row="3" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,15,0,5">
                    <StackPanel>
                        <CheckBox Content="MapScripts更新時にバックアップを作成する"
                                  IsChecked="{Binding EnableMapScriptsBackup}"
                                  ToolTip="MapScripts で上書き前に backup\\MapScripts へバックアップします"
                                  Margin="0,0,0,5"/>
                        <CheckBox Content="SongScripts保存時にバックアップを作成する"
                                  IsChecked="{Binding EnableSongScriptsBackup}"
                                  ToolTip="SongScripts 保存前に backup\\SongScripts へバックアップします"
                                  Margin="0,0,0,5"/>
                        <CheckBox Content="Copier上書き時にバックアップを作成する"
                                  IsChecked="{Binding EnableCopierBackup}"
                                  ToolTip="Copier の上書き前に backup\\Copier へバックアップします"
                                  Margin="0,0,0,5"/>
                        <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap">
                            <Run Text="※バックアップルートが空欄の場合は CameraScriptManager.exe 配下の backup フォルダを使用します。"/>
                        </TextBlock>
                        <Button Content="列の幅をリセット"
                                Command="{Binding ResetColumnWidthsCommand}"
                                Margin="0,10,0,0"
                                Padding="12,4"
                                ToolTip="3タブの保存済み列幅を削除して既定値へ戻します"
                                HorizontalAlignment="Left"/>
                        <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0">
                            <Run Text="※MapScripts / SongScripts / Copier の列幅を既定値に戻します。"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="アプリ情報">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="現在のバージョン:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentVersion}" VerticalAlignment="Center" Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="リリースURL:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Margin="5" VerticalAlignment="Center"
                           ToolTip="クリックすると CameraScriptManager の最新版リリースページを開きます">
                    <Hyperlink NavigateUri="{Binding ReleaseUrl, Mode=OneWay}" navigation:RequestNavigate="ReleaseUrl_RequestNavigate">
                        <Run Text="{Binding ReleaseUrl, Mode=OneWay}"/>
                    </Hyperlink>
                </TextBlock>

                <CheckBox Grid.Row="2" Grid.Column="1"
                          Content="自動アップデートチェック"
                          IsChecked="{Binding EnableAutoUpdateCheck}"
                          Margin="5,8,5,0"
                          ToolTip="起動時に 1 日 1 回以下で最新版を確認します"/>

                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Gray" FontSize="11" TextWrapping="Wrap" Margin="5,4,5,0">
                    <Run Text="※ ON の場合、起動時に release_info.json を確認し、新しいバージョンがあればリリース URL を表示します。"/>
                </TextBlock>
            </Grid>
        </GroupBox>

    </Grid>
</UserControl>
