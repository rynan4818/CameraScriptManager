<UserControl x:Class="CameraScriptManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:CameraScriptManager.Models"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase">

    <UserControl.Resources>
        <ObjectDataProvider x:Key="RenameOptions" MethodName="GetValues" ObjectType="{x:Type models:RenameOption}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:RenameOption"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Paths Configuration -->
        <GroupBox Grid.Row="0" Header="パス設定" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- CustomLevels -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="CustomLevels:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CustomLevelsPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="0" Grid.Column="2" Content="参照..." Command="{Binding BrowseCustomLevelsCommand}" Margin="5"/>

                <!-- CustomWIPLevels -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="CustomWIPLevels:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CustomWIPLevelsPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="1" Grid.Column="2" Content="参照..." Command="{Binding BrowseCustomWIPLevelsCommand}" Margin="5"/>

                <Separator Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10"/>

                <!-- OriginalScript 1 -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="元データ検索(アーカイブ/JSON) 1:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding OriginalScriptPath1, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="3" Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript1Command}" Margin="5"/>

                <!-- OriginalScript 2 -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="元データ検索(アーカイブ/JSON) 2:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding OriginalScriptPath2, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="4" Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript2Command}" Margin="5"/>

                <!-- OriginalScript 3 -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="元データ検索(アーカイブ/JSON) 3:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding OriginalScriptPath3, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="5" Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript3Command}" Margin="5"/>

                <!-- SongScripts -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="SongScripts:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SongScriptsFolderPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="6" Grid.Column="2" Content="参照..." Command="{Binding BrowseSongScriptsFolderCommand}" Margin="5"/>

                <!-- Backup Root -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="バックアップルート:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,5"/>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding BackupRootPath, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="7" Grid.Column="2" Content="参照..." Command="{Binding BrowseBackupRootCommand}" Margin="5"/>
            </Grid>
        </GroupBox>

        <!-- Naming Configurations -->
        <GroupBox Grid.Row="1" Header="命名規則設定" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- MapScripts Zip Naming -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="MapScripts ZIP出力名:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,10"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <RadioButton GroupName="ManagerZipNaming" IsChecked="{Binding IsManagerZipNamingDefault}" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="デフォルト({MapId}_{SongName}_{LevelAuthorName})"/>
                    </RadioButton>
                    <RadioButton Content="カスタム" GroupName="ManagerZipNaming" IsChecked="{Binding IsManagerZipNamingCustom}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding ManagerZipCustomFormat, UpdateSourceTrigger=PropertyChanged}" 
                             IsEnabled="{Binding IsManagerZipNamingCustom}" Width="300" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Copier Rename Naming -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Copier リネーム名:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,10"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox Text="{Binding CopierRenameCustomFormat, UpdateSourceTrigger=PropertyChanged}" 
                             Width="300" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Tags Hint and Copy Buttons -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                    <TextBlock Text="使用可能なタグ (クリックでコピー):" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,5"/>
                    <WrapPanel>
                        <WrapPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Margin" Value="0,0,5,5"/>
                                <Setter Property="Padding" Value="8,2"/>
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Style>
                        </WrapPanel.Resources>
                        <Button Content="{}{MapId}" Command="{Binding CopyTagCommand}" CommandParameter="MapId"/>
                        <Button Content="{}{SongName}" Command="{Binding CopyTagCommand}" CommandParameter="SongName"/>
                        <Button Content="{}{SongSubName}" Command="{Binding CopyTagCommand}" CommandParameter="SongSubName"/>
                        <Button Content="{}{SongAuthorName}" Command="{Binding CopyTagCommand}" CommandParameter="SongAuthorName"/>
                        <Button Content="{}{LevelAuthorName}" Command="{Binding CopyTagCommand}" CommandParameter="LevelAuthorName"/>
                        <Button Content="{}{CameraScriptAuthorName}" Command="{Binding CopyTagCommand}" CommandParameter="CameraScriptAuthorName"/>
                        <Button Content="{}{FileName}" Command="{Binding CopyTagCommand}" CommandParameter="FileName"/>
                        <Button Content="{}{Bpm}" Command="{Binding CopyTagCommand}" CommandParameter="Bpm"/>
                    </WrapPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,5,0,0">
                        <Run Text="※ {FileName} はJSONファイル名、{CameraScriptAuthorName} は作成者（入力値）を指します。"/>
                    </TextBlock>
                </StackPanel>

                <!-- Backup Setting -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="その他の設定:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,15,10,5"/>
                <Border Grid.Row="3" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,15,0,5">
                    <StackPanel>
                        <CheckBox Content="MapScripts更新時にバックアップを作成する"
                                  IsChecked="{Binding EnableMapScriptsBackup}"
                                  Margin="0,0,0,5"/>
                        <CheckBox Content="SongScripts保存時にバックアップを作成する"
                                  IsChecked="{Binding EnableSongScriptsBackup}"
                                  Margin="0,0,0,5"/>
                        <CheckBox Content="Copier上書き時にバックアップを作成する"
                                  IsChecked="{Binding EnableCopierBackup}"
                                  Margin="0,0,0,5"/>
                        <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap">
                            <Run Text="※バックアップルートが空欄の場合は CameraScriptManager.exe 配下の backup フォルダを使用します。"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>

    </Grid>
</UserControl>
