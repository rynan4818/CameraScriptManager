<Window x:Class="CameraScriptManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CameraScriptManager.Converters"
        Title="CameraScriptManager"
        Height="700" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:ModifiedRowBackgroundConverter x:Key="ModifiedBgConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: CustomLevels Path -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="CustomLevels:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding CustomLevelsPath, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
            <Button Grid.Column="2" Content="参照..." Command="{Binding BrowseCustomLevelsCommand}"/>
        </Grid>

        <!-- Row 1: CustomWIPLevels Path -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="CustomWIPLevels:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding CustomWIPLevelsPath, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
            <Button Grid.Column="2" Content="参照..." Command="{Binding BrowseCustomWIPLevelsCommand}"/>
        </Grid>

        <!-- Row 2: Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,8">
            <Button Content="再チェック" Command="{Binding ScanCommand}" Padding="16,4" Margin="0,0,8,0"/>
            <Button Content="メタ情報追加" Command="{Binding AddMetadataCommand}" Padding="16,4" Margin="0,0,8,0"/>
            <Button Content="ZIP出力" Command="{Binding ExportZipCommand}" Padding="16,4"/>
        </StackPanel>

        <!-- Row 3: DataGrid -->
        <DataGrid Grid.Row="3"
                  x:Name="ScriptDataGrid"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#F8F8F8"
                  RowHeaderWidth="0"
                  IsReadOnly="False"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding IsModified, Converter={StaticResource ModifiedBgConverter}}"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="BeatSaverからメタデータ取得" Click="FetchBeatSaver_Click"/>
                    <Separator/>
                    <MenuItem Header="cameraScriptAuthorName ロック" Click="LockAuthor_Click"/>
                    <MenuItem Header="cameraScriptAuthorName ロック解除" Click="UnlockAuthor_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <!-- Select checkbox -->
                <DataGridTemplateColumn Header="選択" Width="40" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Modified indicator -->
                <DataGridTemplateColumn Header="編集済" Width="50" CanUserSort="True" SortMemberPath="IsModified">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsModified, Mode=OneWay}"
                                      IsEnabled="False"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- MapId -->
                <DataGridTextColumn Header="ID" Binding="{Binding MapId, UpdateSourceTrigger=LostFocus}" Width="70"/>

                <!-- CameraScriptAuthorName with lock -->
                <DataGridTemplateColumn Header="cameraScriptAuthorName" Width="160" SortMemberPath="CameraScriptAuthorName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding CameraScriptAuthorName, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsCameraScriptAuthorLocked}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="2,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Song info columns (read-only display, editable) -->
                <DataGridTextColumn Header="songName" Binding="{Binding SongName, UpdateSourceTrigger=LostFocus}" Width="180"/>
                <DataGridTextColumn Header="songSubName" Binding="{Binding SongSubName, UpdateSourceTrigger=LostFocus}" Width="120"/>
                <DataGridTextColumn Header="songAuthorName" Binding="{Binding SongAuthorName, UpdateSourceTrigger=LostFocus}" Width="130"/>
                <DataGridTextColumn Header="levelAuthorName" Binding="{Binding LevelAuthorName, UpdateSourceTrigger=LostFocus}" Width="120"/>
                <DataGridTextColumn Header="BPM" Binding="{Binding Bpm, UpdateSourceTrigger=LostFocus}" Width="60"/>

                <!-- File info (read-only) -->
                <DataGridTextColumn Header="ファイル名" Binding="{Binding FileName}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="フォルダ" Binding="{Binding FolderName}" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="ソース" Binding="{Binding SourceType}" Width="110" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 4: Status bar -->
        <StatusBar Grid.Row="4" Margin="0,4,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
