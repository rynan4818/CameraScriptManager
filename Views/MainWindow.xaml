<Window x:Class="CameraScriptManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CameraScriptManager.Views"
        xmlns:vm="clr-namespace:CameraScriptManager.ViewModels"
        mc:Ignorable="d"
        Title="CameraScript Manager &amp; Copier" Height="750" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <TabControl Margin="5">
            <!-- Manager Tab -->
            <TabItem Header="Manager">
                <local:ManagerView DataContext="{Binding ManagerViewModel}" />
            </TabItem>

            <!-- Copier Tab -->
            <TabItem Header="Copier">
                <local:CopierView DataContext="{Binding CopierViewModel}" />
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <local:SettingsView DataContext="{Binding SettingsViewModel}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
