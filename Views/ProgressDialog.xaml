<Window x:Class="CameraScriptManager.Views.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="処理中..." Height="150" Width="350"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageText" Text="読み込み中..." TextWrapping="Wrap" Margin="0,0,0,15" HorizontalAlignment="Center" FontSize="14"/>
        <ProgressBar x:Name="ProgressBar" Grid.Row="1" IsIndeterminate="True" Height="20" />
    </Grid>
</Window>
