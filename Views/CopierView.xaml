<UserControl x:Class="CameraScriptManager.Views.CopierView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CameraScriptManager.Converters"
        xmlns:views="clr-namespace:CameraScriptManager.Views"
        xmlns:models="clr-namespace:CameraScriptManager.Models"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:NullableBoolToCacheColorConverter x:Key="NullableBoolToCacheColorConverter"/>
        <ObjectDataProvider x:Key="RenameOptions" MethodName="GetValues" ObjectType="{x:Type models:RenameOption}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:RenameOption"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- 非フォーカス（InActive）時の選択状態色を通常時と同じにするためのシステムブラシの上書き -->
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{x:Static SystemColors.HighlightColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{x:Static SystemColors.HighlightTextColor}"/>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Settings & Action Buttons -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,5" VerticalAlignment="Center">
            <CheckBox Content="譜面metadataを表示" IsChecked="{Binding ShowMetadataColumns}" VerticalAlignment="Center" Margin="0,0,15,0"
                      ToolTip="songSubName などの譜面 metadata 列を表示します"/>
            <CheckBox Content="コピー時にmetadataをUI内容で再生成" IsChecked="{Binding AddMetadata}" VerticalAlignment="Center" Margin="0,0,15,0"
                      ToolTip="ON の場合、コピー先 SongScript の metadata を現在の UI の値で再生成します。metadata が無い場合は新規追加します。OFF の場合は元の JSON をそのままコピーします。"/>
            <TextBlock Text="リネーム:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox SelectedItem="{Binding DefaultRenameOption, UpdateSourceTrigger=PropertyChanged}"
                      ItemsSource="{Binding Source={StaticResource RenameOptions}}"
                      IsEditable="False" Width="150" VerticalAlignment="Center" Margin="0,0,15,0"
                      ToolTip="新規コピー時の既定リネーム方式を選択します"/>
            
            <Button Content="再チェック" Command="{Binding RescanCommand}" Width="80" Margin="0,0,5,0"
                    ToolTip="CustomLevels と CustomWIPLevels を再スキャンして照合結果を更新します"/>
            <Button Content="クリア" Command="{Binding ClearEntriesCommand}" Width="60" Margin="0,0,5,0"
                    ToolTip="取り込み済みの一覧をクリアします"/>
            <Button Content="コピー実行" Command="{Binding CopyCommand}" Width="100" FontWeight="Bold" Background="#4CAF50" Foreground="White" Margin="0,0,5,0"
                    ToolTip="チェックされたコピー先へ SongScript をコピーします"/>

            <!-- SongDetailsCache デバッグインジケータ -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <TextBlock Text="Cache:" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,4,0" FontSize="11"/>
                <TextBlock Text="■" FontSize="14" VerticalAlignment="Center"
                           Foreground="{Binding LastCacheLookupSuccess, Converter={StaticResource NullableBoolToCacheColorConverter}}"
                           ToolTip="SongDetailsCache: 緑=ヒット, 赤=ミス, 灰=未実行"/>
                <TextBlock VerticalAlignment="Center" Foreground="Gray" Margin="4,0,0,0" FontSize="11">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Hit:{0} Miss:{1}">
                            <Binding Path="CacheHitCount"/>
                            <Binding Path="CacheMissCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </WrapPanel>

        <!-- Drop Zone -->
        <Border Grid.Row="1" MinHeight="50" BorderBrush="Gray" BorderThickness="2"
                CornerRadius="5" Background="#F5F5F5" Margin="0,0,0,5"
                AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                <TextBlock Text=".json / アーカイブ (.zip/.7z 等) をここにドロップ"
                           Foreground="{DynamicResource MaterialDesignToolTipBackground}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <Button Content="ファイルを選択..." Command="{Binding OpenFilesCommand}" Padding="10,5"
                        ToolTip="JSON やアーカイブから SongScript を取り込みます"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="EntryDataGrid" ItemsSource="{Binding Entries}"
                  views:DataGridColumnWidthPersistence.EnablePersistence="True"
                  views:DataGridColumnWidthPersistence.GridKey="Copier"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectionMode="Extended" RowHeaderWidth="0"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  CanUserSortColumns="True"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#F9F9F9"
                  PreviewMouseLeftButtonDown="EntryDataGrid_PreviewMouseLeftButtonDown"
                  PreviewMouseRightButtonDown="EntryDataGrid_PreviewMouseRightButtonDown">

            <!-- Context Menu -->
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="選択行を削除" 
                              Command="{Binding PlacementTarget.DataContext.DeleteSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="選択したIDをコピー" 
                              Command="{Binding PlacementTarget.DataContext.CopyIdsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="BeatSaverからmetadata取得"
                              Command="{Binding PlacementTarget.DataContext.FetchBeatSaverMetadataCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="選択した未取得譜面を取得"
                              Command="{Binding PlacementTarget.DataContext.DownloadSelectedMissingBeatmapsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator/>
                    <MenuItem Header="Rename">
                        <MenuItem Header="無し" 
                                  Command="{Binding PlacementTarget.DataContext.RenameNoneCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="SongScript" 
                                  Command="{Binding PlacementTarget.DataContext.RenameSongScriptCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="ID_Author_SongName" 
                                  Command="{Binding PlacementTarget.DataContext.RenameIdAuthorSongNameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </MenuItem>
                    <MenuItem Header="Song Name">
                        <MenuItem Header="Sourceから取得 (Default)" 
                                  Command="{Binding PlacementTarget.DataContext.SongNameSourceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="BeatSaverから取得 (songName)" 
                                  Command="{Binding PlacementTarget.DataContext.SongNameBeatSaverCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="BeatSaverから取得 (songName - levelAuthorName)" 
                                  Command="{Binding PlacementTarget.DataContext.SongNameBeatSaverAndAuthorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </MenuItem>
                    <MenuItem Header="CL チェック">
                        <MenuItem Header="ON" 
                                  Command="{Binding PlacementTarget.DataContext.CustomLevelsOnCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="OFF" 
                                  Command="{Binding PlacementTarget.DataContext.CustomLevelsOffCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </MenuItem>
                    <MenuItem Header="WIP チェック">
                        <MenuItem Header="ON" 
                                  Command="{Binding PlacementTarget.DataContext.CustomWipLevelsOnCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="OFF" 
                                  Command="{Binding PlacementTarget.DataContext.CustomWipLevelsOffCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="対象セルの項目をロック" Click="LockCell_Click"/>
                    <MenuItem Header="対象セルの項目をロック解除" Click="UnlockCell_Click"/>
                    <Separator/>
                    <MenuItem Header="エクスプローラーで開く">
                        <MenuItem Header="CustomLevels Folder" 
                                  Command="{Binding PlacementTarget.DataContext.OpenExplorerCLCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="CustomWIPLevels Folder" 
                                  Command="{Binding PlacementTarget.DataContext.OpenExplorerWIPCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <!-- Source Path (left-aligned, sortable) -->
                <DataGridTextColumn Header="ソース" Binding="{Binding SourceDisplayPath}" IsReadOnly="True" Width="200" views:DataGridColumnWidthPersistence.ColumnKey="source_display"
                                    SortMemberPath="SourceDisplayPath"/>

                <!-- Hex ID (editable, lockable) -->
                <DataGridTemplateColumn Header="ID" Width="52" SortMemberPath="HexId" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="hex_id">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding HexId, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsHexIdLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHexIdLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- BeatSaver URL -->
                <DataGridTemplateColumn Header="BeatSaver" Width="84" views:DataGridColumnWidthPersistence.ColumnKey="beat_saver">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Visibility="{Binding CanOpenBeatSaver, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Hyperlink NavigateUri="{Binding BeatSaverUrl}" RequestNavigate="Hyperlink_RequestNavigate">
                                        <Run Text="Open"/>
                                    </Hyperlink>
                                </TextBlock>
                                <Button Content="[取得]"
                                        Padding="4,1"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        ToolTip="この譜面を BeatSaver から取得して CustomLevels に展開します"
                                        Visibility="{Binding CanDownloadMissingBeatmap, Converter={StaticResource BoolToVisibilityConverter}}"
                                        IsEnabled="{Binding CanDownloadMissingBeatmap}"
                                        Command="{Binding DataContext.DownloadMissingBeatmapCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="hash" Width="79" SortMemberPath="Hash" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="hash">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Hash, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsHashLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHashLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Song Name (lockable) -->
                <DataGridTemplateColumn Header="songName" Width="172" SortMemberPath="SongName" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="song_name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SongName, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsSongNameLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSongNameLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Author (sortable, lockable) -->
                <DataGridTemplateColumn Header="cameraScriptAuthorName" Width="149" SortMemberPath="CameraScriptAuthorName" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="camera_script_author">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBox Text="{Binding CameraScriptAuthorName, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsCameraScriptAuthorLocked}"
                                         ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                         BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCameraScriptAuthorLocked}" Value="True">
                                                    <Setter Property="Background" Value="#DDDDDD"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Border Width="6" Height="6" Background="Black" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Cursor="Cross" Tag="{Binding}"
                                        MouseLeftButtonDown="FillHandle_MouseLeftButtonDown"
                                        Visibility="{Binding IsCameraScriptAuthorLocked, Converter={StaticResource InverseBoolConverter}, ConverterParameter=Visibility}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- songSubName (lockable) -->
                <DataGridTemplateColumn x:Name="ColSongSubName" Header="songSubName" Width="120" SortMemberPath="SongSubName" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="song_sub_name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SongSubName, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsSongSubNameLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSongSubNameLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- songAuthorName (lockable) -->
                <DataGridTemplateColumn x:Name="ColSongAuthorName" Header="songAuthorName" Width="130" SortMemberPath="SongAuthorName" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="song_author_name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SongAuthorName, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsSongAuthorNameLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSongAuthorNameLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- levelAuthorName (lockable) -->
                <DataGridTemplateColumn x:Name="ColLevelAuthorName" Header="levelAuthorName" Width="120" SortMemberPath="LevelAuthorName" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="level_author_name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding LevelAuthorName, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsLevelAuthorNameLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLevelAuthorNameLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- BPM (lockable) -->
                <DataGridTemplateColumn x:Name="ColBpm" Header="BPM" Width="50" SortMemberPath="Bpm" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="bpm">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Bpm, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsBpmLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBpmLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn x:Name="ColDuration" Header="Duration" Width="75" SortMemberPath="Duration" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="duration">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Duration, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsDurationLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDurationLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- AvatarHeight (lockable) -->
                <DataGridTemplateColumn Header="AvatarHeight(cm)" Width="105" SortMemberPath="AvatarHeight" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="avatar_height">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding AvatarHeight, TargetNullValue='', UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsAvatarHeightLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAvatarHeightLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Description (lockable) -->
                <DataGridTemplateColumn Header="Description" Width="139" SortMemberPath="Description" HeaderStyle="{StaticResource MetadataColumnHeaderStyle}" views:DataGridColumnWidthPersistence.ColumnKey="description">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsDescriptionLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDescriptionLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- CustomLevels Checkbox -->
                <DataGridTemplateColumn Header="CL" Width="35" views:DataGridColumnWidthPersistence.ColumnKey="cl_check">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding CopyToCustomLevels, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding CanCopyToCustomLevels}"
                                      ToolTip="この SongScript を CustomLevels にコピーします"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- CL Overwrite Warning -->
                <DataGridTemplateColumn Header="!" Width="25" views:DataGridColumnWidthPersistence.ColumnKey="cl_alert">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="Red" CornerRadius="3" 
                                    Width="18" Height="18"
                                    Visibility="{Binding HasOverwriteWarningCL, Converter={StaticResource BoolToVisibilityConverter}}"
                                    ToolTip="このフォルダに同名ファイルが存在するため上書きされます"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="!" Foreground="White" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- CL Folder Count (red if multiple) -->
                <DataGridTemplateColumn Header="CL#" Width="35" views:DataGridColumnWidthPersistence.ColumnKey="cl_count">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CustomLevelsFolderCount}"
                                       Foreground="{Binding HasMultipleCustomLevels, Converter={StaticResource BoolToColorConverter}}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- CL Folder Selector (disabled if single, red if multiple) -->
                <DataGridTemplateColumn Header="CustomLevelsフォルダ" Width="250" views:DataGridColumnWidthPersistence.ColumnKey="custom_levels_folder">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding CustomLevelsFolders}"
                                      SelectedItem="{Binding SelectedCustomLevelsFolder, UpdateSourceTrigger=PropertyChanged}"
                                      Visibility="{Binding CanCopyToCustomLevels, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Foreground="{Binding HasMultipleCustomLevels, Converter={StaticResource BoolToColorConverter}}"
                                      IsEnabled="{Binding HasMultipleCustomLevels}"
                                      DisplayMemberPath="FolderName" IsEditable="False"
                                      ToolTip="コピー先に使う CustomLevels の譜面フォルダを選択します"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- CustomWIPLevels Checkbox -->
                <DataGridTemplateColumn Header="WIP" Width="40" views:DataGridColumnWidthPersistence.ColumnKey="wip_check">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding CopyToCustomWIPLevels, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding CanCopyToCustomWIPLevels}"
                                      ToolTip="この SongScript を CustomWIPLevels にコピーします"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- WIP Overwrite Warning -->
                <DataGridTemplateColumn Header="!" Width="25" views:DataGridColumnWidthPersistence.ColumnKey="wip_alert">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="Red" CornerRadius="3" 
                                    Width="18" Height="18"
                                    Visibility="{Binding HasOverwriteWarningWIP, Converter={StaticResource BoolToVisibilityConverter}}"
                                    ToolTip="このフォルダに同名ファイルが存在するため上書きされます"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="!" Foreground="White" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- WIP Folder Count (red if multiple) -->
                <DataGridTemplateColumn Header="WIP#" Width="40" views:DataGridColumnWidthPersistence.ColumnKey="wip_count">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CustomWIPLevelsFolderCount}"
                                       Foreground="{Binding HasMultipleCustomWIPLevels, Converter={StaticResource BoolToColorConverter}}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- WIP Folder Selector (disabled if single, red if multiple) -->
                <DataGridTemplateColumn Header="CustomWIPLevelsフォルダ" Width="250" views:DataGridColumnWidthPersistence.ColumnKey="custom_wip_levels_folder">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding CustomWIPLevelsFolders}"
                                      SelectedItem="{Binding SelectedCustomWIPLevelsFolder, UpdateSourceTrigger=PropertyChanged}"
                                      Visibility="{Binding CanCopyToCustomWIPLevels, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Foreground="{Binding HasMultipleCustomWIPLevels, Converter={StaticResource BoolToColorConverter}}"
                                      IsEnabled="{Binding HasMultipleCustomWIPLevels}"
                                      DisplayMemberPath="FolderName" IsEditable="False"
                                      ToolTip="コピー先に使う CustomWIPLevels の譜面フォルダを選択します"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Rename Option -->
                <DataGridTemplateColumn Header="リネーム" Width="120" views:DataGridColumnWidthPersistence.ColumnKey="rename_choice">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding RenameChoice, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding Source={StaticResource RenameOptions}}"
                                      IsEditable="False"
                                      ToolTip="この行のリネーム方式を選択します"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Renamed FileName (editable) -->
                <DataGridTextColumn Header="ファイル名" Binding="{Binding RenameDisplayName, UpdateSourceTrigger=LostFocus}" Width="200" views:DataGridColumnWidthPersistence.ColumnKey="rename_file_name"/>

                <!-- Script Duration (MovementsのDuration+Delay合計) -->
                <DataGridTextColumn Header="ｽｸﾘﾌﾟﾄ長" Binding="{Binding ScriptDurationText, Mode=OneWay}" IsReadOnly="True" Width="70" views:DataGridColumnWidthPersistence.ColumnKey="script_duration"/>

                <!-- Ogg Duration -->
                <DataGridTextColumn Header="曲長(egg)" Binding="{Binding OggDurationText, Mode=OneWay}" IsReadOnly="True" Width="70" views:DataGridColumnWidthPersistence.ColumnKey="ogg_duration"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
