<UserControl x:Class="CameraScriptManager.Views.ManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CameraScriptManager.Converters"
        xmlns:views="clr-namespace:CameraScriptManager.Views">
    <UserControl.Resources>
        <converters:ModifiedRowBackgroundConverter x:Key="ModifiedBgConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        
        <!-- 非フォーカス（InActive）時の選択状態色を通常時と同じにするためのシステムブラシの上書き -->
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{x:Static SystemColors.HighlightColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{x:Static SystemColors.HighlightTextColor}"/>

        <!-- Reusable CellStyle for Modified cells -->
        <Style x:Key="ModifiedCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsModified}" Value="True">
                    <Setter Property="Background" Value="#C0FFFF80" />
                    <Setter Property="Foreground" Value="Black" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,8">
            <Button Content="スキャン" Command="{Binding ScanCommand}" Padding="16,4" Margin="0,0,8,0"
                    ToolTip="譜面フォルダをスキャンして一覧を更新します"/>
            <Button Content="メタ情報追加" Command="{Binding AddMetadataCommand}" Padding="16,4" Margin="0,0,8,0"
                    ToolTip="選択中の譜面フォルダ内 SongScript に metadata を追加します"/>
            <Button Content="フォルダ出力" Command="{Binding ExportFolderCommand}" Padding="16,4" Margin="0,0,8,0"
                    ToolTip="選択中の譜面フォルダスクリプトをフォルダへ出力します"/>
            <Button Content="ZIP出力" Command="{Binding ExportZipCommand}" Padding="16,4" Margin="0,0,8,0"
                    ToolTip="選択中の譜面フォルダスクリプトを ZIP で出力します"/>
            <Button Content="プレイリストを作成" Command="{Binding CreatePlaylistCommand}" Padding="16,4" Margin="0,0,8,0"
                    ToolTip="選択中の譜面から Beat Saber 用プレイリストを作成します"/>
            <Button Content="元データ照合" Command="{Binding FindOriginalScriptsCommand}" Padding="16,4"
                    ToolTip="元データ検索パスから一致候補を検索します"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="ScriptDataGrid"
                  ItemsSource="{Binding Items}"
                  views:DataGridColumnWidthPersistence.EnablePersistence="True"
                  views:DataGridColumnWidthPersistence.GridKey="MapScripts"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#F8F8F8"
                  RowHeaderWidth="0"
                  IsReadOnly="False"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  PreviewMouseRightButtonDown="ScriptDataGrid_PreviewMouseRightButtonDown">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="Cut" Header="切り取り" />
                    <MenuItem Command="Copy" Header="コピー" />
                    <MenuItem Command="Paste" Header="貼り付け" />
                    <Separator/>
                    <MenuItem Header="BeatSaverからメタデータ取得" Click="FetchBeatSaver_Click"/>
                    <Separator/>
                    <MenuItem Header="選択したIDをコピー" Click="CopyIds_Click"/>
                    <Separator/>
                    <MenuItem Header="対象セルの項目をロック" Click="LockCell_Click"/>
                    <MenuItem Header="対象セルの項目をロック解除" Click="UnlockCell_Click"/>
                    <Separator/>
                    <MenuItem Header="選択 ON/OFFを切り替え" Click="ToggleSelection_Click"/>
                    <Separator/>
                    <MenuItem Header="エクスプローラーで開く">
                        <MenuItem Header="譜面フォルダ" Click="OpenMapFolder_Click"/>
                        <MenuItem Header="元データ(アーカイブ/JSON) フォルダ" Click="OpenOriginalFolder_Click"/>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <!-- Select checkbox (No BG Color) -->
                <DataGridTemplateColumn Header="選択" Width="40" CanUserSort="False" views:DataGridColumnWidthPersistence.ColumnKey="select">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="この行を各操作の対象に含めます"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Modified indicator -->
                <DataGridTemplateColumn Header="編集済" Width="50" CanUserSort="True" SortMemberPath="IsModified" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="modified">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsModified, Mode=OneWay}"
                                      IsEnabled="False"
                                      ToolTip="この行に未保存の変更があるかを表示します"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- MapId -->
                <DataGridTemplateColumn Header="ID" Width="52" SortMemberPath="MapId" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="map_id">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding MapId, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsMapIdLocked}"
                                     ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                     BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMapIdLocked}" Value="True">
                                                <Setter Property="Background" Value="#DDDDDD"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- CameraScriptAuthorName with lock and drag handle -->
                <DataGridTemplateColumn Header="cameraScriptAuthorName" Width="154" SortMemberPath="CameraScriptAuthorName" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="camera_script_author">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBox Text="{Binding CameraScriptAuthorName, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsCameraScriptAuthorLocked}"
                                         ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                         BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCameraScriptAuthorLocked}" Value="True">
                                                    <Setter Property="Background" Value="#DDDDDD"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <!-- Fill Handle for dragging to copy -->
                                <Border Width="6" Height="6" Background="Black" 
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Cursor="Cross" Tag="{Binding}"
                                        MouseLeftButtonDown="FillHandle_MouseLeftButtonDown"
                                        Visibility="{Binding IsCameraScriptAuthorLocked, Converter={StaticResource InverseBoolConverter}, ConverterParameter=Visibility}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Song info columns (read-only display, editable) with ModifiedCellStyle -->
                <DataGridTemplateColumn Header="songName" Width="180" SortMemberPath="SongName" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="song_name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SongName, UpdateSourceTrigger=LostFocus}" IsReadOnly="{Binding IsSongNameLocked}" ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}" BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsSongNameLocked}" Value="True"><Setter Property="Background" Value="#DDDDDD"/><Setter Property="Foreground" Value="#555555"/></DataTrigger></Style.Triggers></Style></TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="songSubName" Width="120" SortMemberPath="SongSubName" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="song_sub_name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SongSubName, UpdateSourceTrigger=LostFocus}" IsReadOnly="{Binding IsSongSubNameLocked}" ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}" BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsSongSubNameLocked}" Value="True"><Setter Property="Background" Value="#DDDDDD"/><Setter Property="Foreground" Value="#555555"/></DataTrigger></Style.Triggers></Style></TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="songAuthorName" Width="130" SortMemberPath="SongAuthorName" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="song_author_name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SongAuthorName, UpdateSourceTrigger=LostFocus}" IsReadOnly="{Binding IsSongAuthorNameLocked}" ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}" BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsSongAuthorNameLocked}" Value="True"><Setter Property="Background" Value="#DDDDDD"/><Setter Property="Foreground" Value="#555555"/></DataTrigger></Style.Triggers></Style></TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="levelAuthorName" Width="120" SortMemberPath="LevelAuthorName" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="level_author_name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding LevelAuthorName, UpdateSourceTrigger=LostFocus}" IsReadOnly="{Binding IsLevelAuthorNameLocked}" ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}" BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsLevelAuthorNameLocked}" Value="True"><Setter Property="Background" Value="#DDDDDD"/><Setter Property="Foreground" Value="#555555"/></DataTrigger></Style.Triggers></Style></TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="BPM" Width="50" SortMemberPath="Bpm" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="bpm">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Bpm, UpdateSourceTrigger=LostFocus}" IsReadOnly="{Binding IsBpmLocked}" ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}" BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsBpmLocked}" Value="True"><Setter Property="Background" Value="#DDDDDD"/><Setter Property="Foreground" Value="#555555"/></DataTrigger></Style.Triggers></Style></TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="AvatarHeight(cm)" Width="105" SortMemberPath="AvatarHeight" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="avatar_height">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding AvatarHeight, UpdateSourceTrigger=LostFocus}" IsReadOnly="{Binding IsAvatarHeightLocked}" ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}" BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsAvatarHeightLocked}" Value="True"><Setter Property="Background" Value="#DDDDDD"/><Setter Property="Foreground" Value="#555555"/></DataTrigger></Style.Triggers></Style></TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Description" Width="150" SortMemberPath="Description" CellStyle="{StaticResource ModifiedCellStyle}" views:DataGridColumnWidthPersistence.ColumnKey="description">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=LostFocus}" IsReadOnly="{Binding IsDescriptionLocked}" ContextMenu="{Binding ContextMenu, RelativeSource={RelativeSource AncestorType=DataGrid}}" BorderThickness="0" Padding="2,0" VerticalAlignment="Center">
                                <TextBox.Style><Style TargetType="TextBox"><Setter Property="Background" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding IsDescriptionLocked}" Value="True"><Setter Property="Background" Value="#DDDDDD"/><Setter Property="Foreground" Value="#555555"/></DataTrigger></Style.Triggers></Style></TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="曲長(egg)" Binding="{Binding OggDurationText, Mode=OneWay}" Width="70" IsReadOnly="True" views:DataGridColumnWidthPersistence.ColumnKey="ogg_duration" />
                <DataGridTextColumn Header="ｽｸﾘﾌﾟﾄ長" Binding="{Binding ScriptDurationText, Mode=OneWay}" Width="70" IsReadOnly="True" views:DataGridColumnWidthPersistence.ColumnKey="script_duration" />
                <DataGridTextColumn Header="差分(beat)" Binding="{Binding DurationDiffBeatText, Mode=OneWay}" Width="70" IsReadOnly="True" views:DataGridColumnWidthPersistence.ColumnKey="duration_diff" />

                <!-- File info (read-only, no BG color change) -->
                <DataGridTextColumn Header="ファイル名" Binding="{Binding FileName}" Width="140" IsReadOnly="True" views:DataGridColumnWidthPersistence.ColumnKey="file_name"/>
                <DataGridTextColumn Header="フォルダ" Binding="{Binding FolderName}" Width="200" IsReadOnly="True" views:DataGridColumnWidthPersistence.ColumnKey="folder_name"/>
                <DataGridTextColumn Header="ソース" Binding="{Binding SourceType}" Width="110" IsReadOnly="True" views:DataGridColumnWidthPersistence.ColumnKey="source_type"/>
                <DataGridTemplateColumn Header="元データ(アーカイブ/JSON)" Width="250" IsReadOnly="True" views:DataGridColumnWidthPersistence.ColumnKey="original_sources">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ListBox ItemsSource="{Binding OriginalSourceFiles}" 
                                     SelectedItem="{Binding SelectedOriginalSourceFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#0055AA"
                                     MaxHeight="60"
                                     ToolTip="元データ照合で見つかった候補です。選択した項目を関連操作の対象に使います"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Hash -->
                <DataGridTextColumn Header="ハッシュ" Binding="{Binding Hash, Mode=OneWay}" Width="150" IsReadOnly="True" views:DataGridColumnWidthPersistence.ColumnKey="hash"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <StatusBar Grid.Row="2" Margin="0,4,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
