<UserControl x:Class="CameraScriptManager.Views.ManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:CameraScriptManager.Converters">
    <UserControl.Resources>
        <converters:ModifiedRowBackgroundConverter x:Key="ModifiedBgConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        
        <!-- Reusable CellStyle for Modified cells -->
        <Style x:Key="ModifiedCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsModified}" Value="True">
                    <Setter Property="Background" Value="#C0FFFF80" />
                    <Setter Property="Foreground" Value="Black" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: CustomLevels Path -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="CustomLevels:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding CustomLevelsPath, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
            <Button Grid.Column="2" Content="参照..." Command="{Binding BrowseCustomLevelsCommand}"/>
        </Grid>

        <!-- Row 1: CustomWIPLevels Path -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="CustomWIPLevels:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding CustomWIPLevelsPath, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
            <Button Grid.Column="2" Content="参照..." Command="{Binding BrowseCustomWIPLevelsCommand}"/>
        </Grid>

        <!-- Row 2: OriginalScript Path 1 -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="元データ検索(ZIP/JSON) 1:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding OriginalScriptPath1, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
            <Button Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript1Command}"/>
        </Grid>

        <!-- Row 3: OriginalScript Path 2 -->
        <Grid Grid.Row="3" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="元データ検索(ZIP/JSON) 2:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding OriginalScriptPath2, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
            <Button Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript2Command}"/>
        </Grid>

        <!-- Row 4: OriginalScript Path 3 -->
        <Grid Grid.Row="4" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="元データ検索(ZIP/JSON) 3:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding OriginalScriptPath3, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
            <Button Grid.Column="2" Content="参照..." Command="{Binding BrowseOriginalScript3Command}"/>
        </Grid>

        <!-- Row 5: Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,4,0,8">
            <Button Content="再チェック" Command="{Binding ScanCommand}" Padding="16,4" Margin="0,0,8,0"/>
            <Button Content="メタ情報追加" Command="{Binding AddMetadataCommand}" Padding="16,4" Margin="0,0,8,0"/>
            <Button Content="ZIP出力" Command="{Binding ExportZipCommand}" Padding="16,4" Margin="0,0,8,0"/>
            <Button Content="元データ照合" Command="{Binding FindOriginalScriptsCommand}" Padding="16,4"/>
        </StackPanel>

        <!-- Row 6: DataGrid -->
        <DataGrid Grid.Row="6"
                  x:Name="ScriptDataGrid"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#F8F8F8"
                  RowHeaderWidth="0"
                  IsReadOnly="False"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="BeatSaverからメタデータ取得" Click="FetchBeatSaver_Click"/>
                    <Separator/>
                    <MenuItem Header="選択したIDをコピー" Click="CopyIds_Click"/>
                    <Separator/>
                    <MenuItem Header="cameraScriptAuthorName ロック" Click="LockAuthor_Click"/>
                    <MenuItem Header="cameraScriptAuthorName ロック解除" Click="UnlockAuthor_Click"/>
                    <Separator/>
                    <MenuItem Header="選択 ON/OFFを切り替え" Click="ToggleSelection_Click"/>
                    <Separator/>
                    <MenuItem Header="エクスプローラーで開く">
                        <MenuItem Header="譜面フォルダ" Click="OpenMapFolder_Click"/>
                        <MenuItem Header="元データ(ZIP/JSON) フォルダ" Click="OpenOriginalFolder_Click"/>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <!-- Select checkbox (No BG Color) -->
                <DataGridTemplateColumn Header="選択" Width="40" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Modified indicator -->
                <DataGridTemplateColumn Header="編集済" Width="50" CanUserSort="True" SortMemberPath="IsModified" CellStyle="{StaticResource ModifiedCellStyle}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsModified, Mode=OneWay}"
                                      IsEnabled="False"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- MapId -->
                <DataGridTextColumn Header="ID" Binding="{Binding MapId, UpdateSourceTrigger=LostFocus}" Width="70" CellStyle="{StaticResource ModifiedCellStyle}"/>

                <!-- CameraScriptAuthorName with lock and drag handle -->
                <DataGridTemplateColumn Header="cameraScriptAuthorName" Width="160" SortMemberPath="CameraScriptAuthorName" CellStyle="{StaticResource ModifiedCellStyle}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBox Text="{Binding CameraScriptAuthorName, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsCameraScriptAuthorLocked}"
                                         BorderThickness="0"
                                         Padding="2,0"
                                         VerticalAlignment="Center">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCameraScriptAuthorLocked}" Value="True">
                                                    <Setter Property="Background" Value="#DDDDDD"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <!-- Fill Handle for dragging to copy -->
                                <Border Width="6" Height="6" Background="Black" 
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Cursor="Cross" Tag="{Binding}"
                                        MouseLeftButtonDown="FillHandle_MouseLeftButtonDown"
                                        Visibility="{Binding IsCameraScriptAuthorLocked, Converter={StaticResource InverseBoolConverter}, ConverterParameter=Visibility}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Song info columns (read-only display, editable) with ModifiedCellStyle -->
                <DataGridTextColumn Header="songName" Binding="{Binding SongName, UpdateSourceTrigger=LostFocus}" Width="180" CellStyle="{StaticResource ModifiedCellStyle}"/>
                <DataGridTextColumn Header="songSubName" Binding="{Binding SongSubName, UpdateSourceTrigger=LostFocus}" Width="120" CellStyle="{StaticResource ModifiedCellStyle}"/>
                <DataGridTextColumn Header="songAuthorName" Binding="{Binding SongAuthorName, UpdateSourceTrigger=LostFocus}" Width="130" CellStyle="{StaticResource ModifiedCellStyle}"/>
                <DataGridTextColumn Header="levelAuthorName" Binding="{Binding LevelAuthorName, UpdateSourceTrigger=LostFocus}" Width="120" CellStyle="{StaticResource ModifiedCellStyle}"/>
                <DataGridTextColumn Header="BPM" Binding="{Binding Bpm, UpdateSourceTrigger=LostFocus}" Width="50" CellStyle="{StaticResource ModifiedCellStyle}"/>
                <DataGridTextColumn Header="曲長(ogg)" Binding="{Binding OggDurationText, Mode=OneWay}" Width="70" IsReadOnly="True" />
                <DataGridTextColumn Header="ｽｸﾘﾌﾟﾄ長" Binding="{Binding ScriptDurationText, Mode=OneWay}" Width="70" IsReadOnly="True" />

                <!-- File info (read-only, no BG color change) -->
                <DataGridTextColumn Header="ファイル名" Binding="{Binding FileName}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="フォルダ" Binding="{Binding FolderName}" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Header="ソース" Binding="{Binding SourceType}" Width="110" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="元データ(ZIP/JSON)" Width="250" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ListBox ItemsSource="{Binding OriginalSourceFiles}" 
                                     SelectedItem="{Binding SelectedOriginalSourceFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#0055AA"
                                     MaxHeight="60"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 7: Status bar -->
        <StatusBar Grid.Row="7" Margin="0,4,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
