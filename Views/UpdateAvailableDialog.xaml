<Window x:Class="CameraScriptManager.Views.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:navigation="clr-namespace:System.Windows.Navigation;assembly=PresentationFramework"
        Title="アップデートがあります"
        Height="240"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Text="新しい CameraScriptManager が公開されています。"
                   FontSize="15"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,14"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="現在のバージョン:" FontWeight="Bold" Margin="0,0,12,8" VerticalAlignment="Center"/>
        <TextBlock x:Name="CurrentVersionText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="最新バージョン:" FontWeight="Bold" Margin="0,0,12,8" VerticalAlignment="Center"/>
        <TextBlock x:Name="LatestVersionText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,4,0,0">
            <TextBlock FontWeight="Bold" Margin="0,0,0,6">最新版リリース:</TextBlock>
            <TextBlock TextWrapping="Wrap">
                <Hyperlink x:Name="ReleaseLink"
                           navigation:RequestNavigate="ReleaseLink_RequestNavigate">
                    <Run x:Name="ReleaseLinkText"/>
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="OpenReleaseButton"
                    Content="リリースを開く"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="OpenRelease_Click"
                    IsDefault="True"/>
            <Button Content="閉じる"
                    Width="90"
                    Click="Close_Click"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
